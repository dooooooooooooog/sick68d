/*
 * SiCK-68 ZMK Shield Overlay
 * Controller: Nice!Nano (nRF52840)
 *
 * Using native &gpio0 / &gpio1 pins directly instead of &pro_micro
 * to avoid pro_micro gpio-map boundary issues.
 *
 * Nice!Nano v2 physical pin → nRF52840 GPIO mapping:
 *
 *  Left side  (top to bottom):
 *   Pin 1  → P0.06   (D1 / TX)
 *   Pin 2  → P0.08   (D0 / RX)
 *   Pin 3  → P0.17   (D2)
 *   Pin 4  → P0.20   (D3)
 *   Pin 5  → P0.22   (D4)
 *   Pin 6  → P0.24   (D5)
 *   Pin 7  → P1.00   (D6)
 *   Pin 8  → P0.11   (D7)
 *   Pin 9  → P1.04   (D8)
 *   Pin 10 → P1.06   (D9)
 *
 *  Right side (top to bottom, skipping VCC/RAW/RST/GND):
 *   Pin 21 → P0.31   (A0)
 *   Pin 20 → P0.29   (A1)
 *   Pin 19 → P0.02   (A2)
 *   Pin 18 → P1.15   (A3)
 *   Pin 17 → P1.13   (A4)
 *   Pin 16 → P1.11   (A5)
 *   Pin 15 → P0.10   (15)
 *   Pin 14 → P0.09   (14)  -- also SDA
 *   Pin 13 → P0.13   -- actually "SCL" labelled pin on nice_nano
 *             wait — see note below
 *
 * ⚠️  nice_nano only exposes these pins safely. We have 15 cols + 5 rows = 20 pins needed.
 *     All 20 fit within the available GPIOs below.
 *
 * Rows (5):   use left-side pins D2–D6  (P0.17, P0.20, P0.22, P0.24, P1.00)
 * Cols (15):  use D7,D8,D9 + A0–A5 + pins 14,15 + D0,D1 + two more (P1.02, P1.04 re-used carefully)
 *
 * Final safe assignment:
 *  Row 0 (B0) → P0.17
 *  Row 1 (B1) → P0.20
 *  Row 2 (B2) → P0.22
 *  Row 3 (B3) → P0.24
 *  Row 4 (B7) → P1.00
 *
 *  Col  0 (F5) → P0.31  (A0)
 *  Col  1 (F6) → P0.29  (A1)
 *  Col  2 (F7) → P0.02  (A2)
 *  Col  3 (B6) → P1.15  (A3)
 *  Col  4 (B5) → P1.13  (A4)
 *  Col  5 (B4) → P1.11  (A5)
 *  Col  6 (D7) → P0.10  (15)
 *  Col  7 (D4) → P0.09  (14)
 *  Col  8 (D5) → P0.08  (D0/RX)
 *  Col  9 (C7) → P0.06  (D1/TX)
 *  Col 10 (C6) → P0.11  (D7)
 *  Col 11 (D3) → P1.04  (D8)
 *  Col 12 (D2) → P1.06  (D9)
 *  Col 13 (D1) → P0.04  -- nice_nano SDA (check if available on your board)
 *  Col 14 (D0) → P0.26  -- nice_nano SCL (check if available on your board)
 *
 * ⚠️  If P0.04 or P0.26 are not broken out on your board,
 *     you may need to remap col 13 and col 14 to different pins.
 *     Some Nice!Nano variants label these as I2C pins and do expose them.
 */

#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <15>;
        rows = <5>;

        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11)          RC(2,13) RC(2,14)
            RC(3,0)           RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)  RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
            RC(4,0)  RC(4,1)  RC(4,2)                    RC(4,6)                     RC(4,9)  RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        row-gpios
            = <&gpio0 17 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 0: B0 */
            , <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 1: B1 */
            , <&gpio0 22 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 2: B2 */
            , <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 3: B3 */
            , <&gpio1  0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* Row 4: B7 */
            ;

        col-gpios
            = <&gpio0 31 GPIO_ACTIVE_HIGH>   /* Col  0: F5 */
            , <&gpio0 29 GPIO_ACTIVE_HIGH>   /* Col  1: F6 */
            , <&gpio0  2 GPIO_ACTIVE_HIGH>   /* Col  2: F7 */
            , <&gpio1 15 GPIO_ACTIVE_HIGH>   /* Col  3: B6 */
            , <&gpio1 13 GPIO_ACTIVE_HIGH>   /* Col  4: B5 */
            , <&gpio1 11 GPIO_ACTIVE_HIGH>   /* Col  5: B4 */
            , <&gpio0 10 GPIO_ACTIVE_HIGH>   /* Col  6: D7 */
            , <&gpio0  9 GPIO_ACTIVE_HIGH>   /* Col  7: D4 */
            , <&gpio0  8 GPIO_ACTIVE_HIGH>   /* Col  8: D5 */
            , <&gpio0  6 GPIO_ACTIVE_HIGH>   /* Col  9: C7 */
            , <&gpio0 11 GPIO_ACTIVE_HIGH>   /* Col 10: C6 */
            , <&gpio1  4 GPIO_ACTIVE_HIGH>   /* Col 11: D3 */
            , <&gpio1  6 GPIO_ACTIVE_HIGH>   /* Col 12: D2 */
            , <&gpio0  4 GPIO_ACTIVE_HIGH>   /* Col 13: D1 */
            , <&gpio0 26 GPIO_ACTIVE_HIGH>   /* Col 14: D0 */
            ;
    };
};
